# ==========================================
# webLing environment configuration (example)
# Copy to .env and adjust.
# ==========================================

# -- Backend --
WEBLING_ENV=development
WEBLING_HOST=0.0.0.0
WEBLING_PORT=8000
WEBLING_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Ling project path (sys.path injection target)
LING_REPO_PATH=/Users/zert/Work/zert/lkl_code/Ling

# -- LLM (MiniMax OpenAI-compatible) --
LLM_BASE_URL=http://192.168.251.56:8080/v1
LLM_API_KEY=dummy
LLM_MODEL=MiniMax-M2.5

# -- TTS (CosyVoice) --
TTS_BASE_URL=http://192.168.251.56:5001
TTS_DEFAULT_SPK_ID=default
TTS_CACHE_DIR=backend/app/static/tts
TTS_CACHE_TTL_SECONDS=3600

# -- MongoDB --
MONGO_URI=mongodb://localhost:27017
MONGO_DB=webling

# -- Auth (JWT) --
JWT_SECRET=change-me-in-prod
JWT_ALGORITHM=HS256
JWT_EMBED_TTL_SECONDS=3600
JWT_REFRESH_TTL_SECONDS=86400

# -- Rate limit --
RATE_LIMIT_PER_MIN=60
QUOTA_PER_DAY=2000

# -- Frontend (apps/web, Vite) --
VITE_API_BASE=http://localhost:8000
VITE_WS_BASE=ws://localhost:8000
