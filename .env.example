# ==========================================
# webLing environment configuration (example)
# Copy to .env and adjust.
# ==========================================

# -- Backend --
WEBLING_ENV=development
WEBLING_HOST=0.0.0.0
WEBLING_PORT=8000
WEBLING_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Ling project path (sys.path injection target)
LING_REPO_PATH=/Users/zert/Work/zert/lkl_code/Ling

# -- LLM (MiniMax OpenAI-compatible) --
LLM_BASE_URL=http://192.168.251.56:8080/v1
LLM_API_KEY=dummy
LLM_MODEL=MiniMax-M2.5

# -- TTS (CosyVoice) --
# CosyVoice 作为独立 docker-compose 部署在 deploy/tts/，默认端口 5001。
# - 本机部署：TTS_BASE_URL=http://host.docker.internal:5001（docker 场景）或 http://localhost:5001（裸跑）
# - 远端部署：改成对应 IP，如 http://192.168.251.56:5001
TTS_PROVIDER=cosyvoice
TTS_BASE_URL=http://192.168.251.56:5001
# Leave empty to use zero-shot TTS (no voice cloning). Set to a registered
# spk_id from `GET /tts/speakers` to enable cloning. M12 adds upload/register
# so new voices can be added via webLing.
TTS_DEFAULT_SPK_ID=
TTS_CACHE_DIR=backend/app/static/tts
TTS_CACHE_TTL_SECONDS=3600

# -- ASR (FunASR) --
# FunASR 2pass 作为独立 docker-compose 部署在 deploy/funasr/，默认端口 10095。
FUNASR_WS_URL=ws://192.168.251.56:10095

# -- MongoDB --
MONGO_URI=mongodb://localhost:27017
MONGO_DB=webling

# -- Auth (JWT) --
JWT_SECRET=change-me-in-prod
JWT_ALGORITHM=HS256
JWT_EMBED_TTL_SECONDS=3600
JWT_REFRESH_TTL_SECONDS=86400

# -- Rate limit --
RATE_LIMIT_PER_MIN=60
QUOTA_PER_DAY=2000

# -- Frontend (apps/web, Vite) --
VITE_API_BASE=http://localhost:8000
VITE_WS_BASE=ws://localhost:8000
