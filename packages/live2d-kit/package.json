{
  "name": "@webling/live2d-kit",
  "version": "0.0.1",
  "description": "Live2D 渲染封装：PIXI 舞台 + 嘴型同步 + 情绪动作",
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "files": ["src"],
  "scripts": {
    "build": "tsc -p tsconfig.build.json || echo 'no build yet'",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "lint": "eslint src --max-warnings 0 || true"
  },
  "peerDependencies": {
    "@webling/core": "workspace:*"
  },
  "devDependencies": {
    "@webling/core": "workspace:*",
    "typescript": "~5.6.3",
    "vitest": "^2.1.8"
  }
}
