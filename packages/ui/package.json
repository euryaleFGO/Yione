{
  "name": "@webling/ui",
  "version": "0.0.1",
  "description": "webLing Vue 组件库（ChatBubble / InputBar / AvatarStage / ...）",
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "files": ["src"],
  "scripts": {
    "build": "tsc -p tsconfig.build.json || echo 'no build yet'",
    "typecheck": "vue-tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "lint": "eslint src --max-warnings 0 || true"
  },
  "peerDependencies": {
    "@webling/core": "workspace:*",
    "@webling/live2d-kit": "workspace:*",
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@webling/core": "workspace:*",
    "@webling/live2d-kit": "workspace:*",
    "typescript": "~5.6.3",
    "vitest": "^2.1.8",
    "vue": "^3.5.32",
    "vue-tsc": "^2.2.0"
  }
}
