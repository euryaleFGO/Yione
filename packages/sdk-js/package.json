{
  "name": "@webling/sdk",
  "version": "0.0.1",
  "description": "裸 JS 调用 webLing 后端 API（给接入方 Node/Deno 用）",
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "files": ["src"],
  "scripts": {
    "build": "tsc -p tsconfig.build.json || echo 'no build yet'",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "lint": "eslint src --max-warnings 0 || true"
  },
  "devDependencies": {
    "typescript": "~5.6.3",
    "vitest": "^2.1.8"
  }
}
